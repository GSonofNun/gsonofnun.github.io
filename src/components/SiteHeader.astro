---
import ThemeToggle from './ThemeToggle.astro';
---

<header class="site-header">
  <div class="wrap site-header__inner">
    <a class="wordmark" href="#top" aria-label="Joshua Grzybowski — home">
      <span class="wordmark__mark" aria-hidden="true">JG</span>
      <span class="wordmark__name">Joshua Grzybowski</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <a href="#work">Work</a>
      <a href="#approach">Approach</a>
      <a href="#about">About</a>
      <a href="#contact">Contact</a>
    </nav>

    <div class="site-header__actions">
      <ThemeToggle />

      <details class="nav-menu">
        <summary class="nav-menu__btn" aria-label="Open navigation menu">
          <svg class="nav-menu__icon nav-menu__icon--open" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
          <svg class="nav-menu__icon nav-menu__icon--close" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
        </summary>
        <nav class="nav-menu__panel" aria-label="Primary (mobile)">
          <a href="#work">Work</a>
          <a href="#approach">Approach</a>
          <a href="#about">About</a>
          <a href="#contact">Contact</a>
        </nav>
      </details>
    </div>
  </div>
</header>

<script is:inline>
  // Close the mobile disclosure after an in-page jump so the panel doesn't
  // linger over the target section. No framework — just the native element.
  (function () {
    var menu = document.querySelector('.nav-menu');
    if (!menu) return;
    menu.querySelectorAll('.nav-menu__panel a').forEach(function (a) {
      a.addEventListener('click', function () {
        menu.open = false;
      });
    });
  })();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--bg) 78%, transparent);
    backdrop-filter: blur(14px) saturate(1.1);
    -webkit-backdrop-filter: blur(14px) saturate(1.1);
    border-bottom: 1px solid var(--hairline);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    height: 64px;
  }
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
  }
  .wordmark__mark {
    font-family: var(--font-display);
    font-weight: 480;
    font-size: 1.05rem;
    letter-spacing: -0.02em;
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border: 1px solid var(--hairline-strong);
    border-radius: 7px;
    color: var(--ink);
    flex: none;
  }
  .wordmark__name {
    font-size: var(--step--1);
    letter-spacing: 0.02em;
    color: var(--ink-2);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .wordmark:hover .wordmark__name {
    color: var(--ink);
  }
  .site-nav {
    display: none;
    gap: clamp(var(--space-4), 2.5vw, var(--space-7));
    margin-left: auto;
    margin-right: var(--space-5);
  }
  .site-nav a {
    font-size: var(--step--1);
    color: var(--ink-2);
    letter-spacing: 0.02em;
    position: relative;
    padding-block: var(--space-2);
    transition: color 0.2s var(--ease);
  }
  .site-nav a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s var(--ease);
  }
  .site-nav a:hover {
    color: var(--ink);
  }
  .site-nav a:hover::after {
    transform: scaleX(1);
  }
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* ---- Mobile disclosure nav (shown < 720px) ---------------------------- */
  .nav-menu {
    position: relative;
  }
  .nav-menu__btn {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--hairline-strong);
    border-radius: var(--radius-sm);
    color: var(--ink-2);
    list-style: none;
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease);
  }
  .nav-menu__btn::-webkit-details-marker {
    display: none;
  }
  .nav-menu__btn:hover {
    color: var(--ink);
    border-color: var(--ink-3);
  }
  .nav-menu__icon--close {
    display: none;
  }
  .nav-menu[open] .nav-menu__icon--open {
    display: none;
  }
  .nav-menu[open] .nav-menu__icon--close {
    display: block;
  }
  .nav-menu__panel {
    position: absolute;
    top: calc(100% + var(--space-3));
    right: 0;
    display: flex;
    flex-direction: column;
    min-width: 180px;
    padding: var(--space-2);
    background: color-mix(in oklab, var(--bg-2) 96%, transparent);
    backdrop-filter: blur(14px) saturate(1.1);
    -webkit-backdrop-filter: blur(14px) saturate(1.1);
    border: 1px solid var(--hairline-strong);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-card);
  }
  .nav-menu__panel a {
    font-size: var(--step-0);
    color: var(--ink-2);
    letter-spacing: 0.02em;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-sm);
    transition: color 0.2s var(--ease), background-color 0.2s var(--ease);
  }
  .nav-menu__panel a:hover {
    color: var(--ink);
    background: var(--bg-3);
  }

  @media (min-width: 720px) {
    .site-nav {
      display: flex;
    }
    .nav-menu {
      display: none;
    }
  }
</style>
