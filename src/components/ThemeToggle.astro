---
// Light/dark toggle. The initial theme is set pre-paint in Base.astro; this only
// flips + persists. No framework — a tiny inline handler.
---

<button
  id="theme-toggle"
  class="theme-toggle"
  type="button"
  aria-label="Switch to light theme"
  title="Toggle theme"
>
  <svg class="theme-toggle__icon theme-toggle__sun" viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
    <circle cx="12" cy="12" r="4.2" fill="currentColor"></circle>
    <g stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
      <line x1="12" y1="2.5" x2="12" y2="5"></line>
      <line x1="12" y1="19" x2="12" y2="21.5"></line>
      <line x1="2.5" y1="12" x2="5" y2="12"></line>
      <line x1="19" y1="12" x2="21.5" y2="12"></line>
      <line x1="5.1" y1="5.1" x2="6.9" y2="6.9"></line>
      <line x1="17.1" y1="17.1" x2="18.9" y2="18.9"></line>
      <line x1="5.1" y1="18.9" x2="6.9" y2="17.1"></line>
      <line x1="17.1" y1="6.9" x2="18.9" y2="5.1"></line>
    </g>
  </svg>
  <svg class="theme-toggle__icon theme-toggle__moon" viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
    <path
      d="M20 14.5A8 8 0 0 1 9.5 4a0.6 0.6 0 0 0-0.82-0.75A9.2 9.2 0 1 0 20.75 15.3 0.6 0.6 0 0 0 20 14.5Z"
      fill="currentColor"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid var(--hairline);
    color: var(--ink-2);
    transition: color 0.25s var(--ease), border-color 0.25s var(--ease),
      background-color 0.25s var(--ease);
  }
  .theme-toggle:hover {
    color: var(--ink);
    border-color: var(--hairline-strong);
    background: var(--bg-2);
  }
  .theme-toggle__icon {
    grid-area: 1 / 1;
    transition: opacity 0.3s var(--ease), transform 0.4s var(--ease);
  }
  /* dark theme shows the sun (tap to go light); light shows the moon */
  :root[data-theme='dark'] .theme-toggle__moon,
  :root[data-theme='light'] .theme-toggle__sun {
    opacity: 0;
    transform: scale(0.5) rotate(-40deg);
  }
  :root[data-theme='dark'] .theme-toggle__sun,
  :root[data-theme='light'] .theme-toggle__moon {
    opacity: 1;
    transform: scale(1) rotate(0);
  }
</style>

<script>
  const btn = document.getElementById('theme-toggle');
  function sync() {
    const isDark = document.documentElement.dataset.theme !== 'light';
    btn?.setAttribute('aria-label', isDark ? 'Switch to light theme' : 'Switch to dark theme');
  }
  btn?.addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
    document.documentElement.dataset.theme = next;
    try {
      localStorage.setItem('theme', next);
    } catch {}
    sync();
  });
  sync();
</script>
