---
/**
 * Hero — name, positioning, and the "Structure" moment.
 *
 * The lattice below is GENERATED at build time (deterministic, seeded) and shipped
 * as inline SVG. It is the always-present base layer and the complete
 * reduced-motion / no-JS fallback. In Phase 3 a lazy three.js island layers an
 * animated 3D version on top of the same region and fades this out once live.
 */

// --- deterministic generative lattice -------------------------------------
const W = 1240;
const H = 720;
// Kept deliberately light: this static SVG is the no-JS / reduced-motion / mobile
// baseline. Fewer nodes => cheap to paint on throttled mobile CPUs (it is never the
// animated path — desktop swaps in the three.js scene over it).
const COLS = 11;
const ROWS = 7;

function mulberry32(seed: number) {
  return function () {
    seed |= 0;
    seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rand = mulberry32(73939133);

type Pt = { x: number; y: number; r: number };
const nodes: Pt[][] = [];
for (let j = 0; j < ROWS; j++) {
  const row: Pt[] = [];
  // gentle vertical perspective: upper rows compress toward the centre
  const t = j / (ROWS - 1);
  const inset = (1 - t) * 0.16; // top rows pulled inward
  for (let i = 0; i < COLS; i++) {
    const u = i / (COLS - 1);
    const x = (inset + u * (1 - 2 * inset)) * W;
    const y = (0.08 + t * 0.84) * H;
    const jitter = 14 * (1 - 0.5 * t);
    row.push({
      x: x + (rand() - 0.5) * jitter,
      y: y + (rand() - 0.5) * jitter,
      r: 1.1 + rand() * 1.4,
    });
  }
  nodes.push(row);
}

type Seg = { x1: number; y1: number; x2: number; y2: number; o: number };
const segs: Seg[] = [];
const push = (a: Pt, b: Pt, o: number) =>
  segs.push({ x1: a.x, y1: a.y, x2: b.x, y2: b.y, o });

for (let j = 0; j < ROWS; j++) {
  for (let i = 0; i < COLS; i++) {
    const a = nodes[j]![i]!;
    if (i + 1 < COLS) push(a, nodes[j]![i + 1]!, 0.5);
    if (j + 1 < ROWS) push(a, nodes[j + 1]![i]!, 0.42);
    // a sparse diagonal brace — the "truss" read
    if (i + 1 < COLS && j + 1 < ROWS && rand() > 0.62)
      push(a, nodes[j + 1]![i + 1]!, 0.22);
  }
}
const flatNodes = nodes.flat();
---

<section id="top" class="hero">
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__canvas" id="lattice-canvas" data-lattice></div>
    <svg
      class="hero__lattice"
      viewBox={`0 0 ${W} ${H}`}
      preserveAspectRatio="xMidYMid slice"
      role="presentation"
    >
      <g class="hero__lines">
        {
          segs.map((s) => (
            <line
              x1={s.x1.toFixed(1)}
              y1={s.y1.toFixed(1)}
              x2={s.x2.toFixed(1)}
              y2={s.y2.toFixed(1)}
              style={`opacity:${s.o}`}
            />
          ))
        }
      </g>
      <g class="hero__nodes">
        {flatNodes.map((n) => <circle cx={n.x.toFixed(1)} cy={n.y.toFixed(1)} r={n.r.toFixed(2)} />)}
      </g>
    </svg>
    <div class="hero__veil"></div>
  </div>

  <div class="wrap hero__content">
    <p class="eyebrow hero__eyebrow">Native Windows · systems engineering</p>
    <h1 class="hero__title">Joshua<br />Grzybowski</h1>
    <p class="hero__lede">
      I build native Windows software — custom Win2D, Direct2D and D3D renderers, piece
      tables, zero-allocation hot paths. The hard parts, by hand, because the platform
      default wasn’t good enough.
    </p>
    <div class="hero__cta">
      <a href="#work" class="btn btn--primary">See the work</a>
      <a href="#approach" class="btn btn--ghost">How I build</a>
    </div>
  </div>

  <a class="hero__scroll" href="#work" aria-label="Scroll to work">
    <span>Selected work</span>
    <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
      <path d="M12 4v15m0 0 6-6m-6 6-6-6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: clamp(640px, 96svh, 1100px);
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .hero__canvas {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .hero__lattice {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--accent);
    transition: opacity 0.8s var(--ease);
  }
  /* When the animated island takes over it sets this flag to retire the static base */
  .hero__bg[data-live='true'] .hero__lattice {
    opacity: 0;
  }
  .hero__lines line {
    stroke: currentColor;
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }
  .hero__nodes circle {
    fill: var(--ink);
    opacity: 0.5;
  }
  :root[data-theme='dark'] .hero__lattice {
    opacity: 0.55;
  }
  :root[data-theme='light'] .hero__lattice {
    opacity: 0.4;
  }
  /* radial veil keeps text legible over the lattice */
  .hero__veil {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      radial-gradient(120% 90% at 18% 42%, var(--bg) 0%, color-mix(in oklab, var(--bg) 35%, transparent) 45%, transparent 72%),
      linear-gradient(to bottom, transparent 55%, var(--bg) 100%);
  }

  .hero__content {
    position: relative;
    padding-block: var(--space-9);
    max-width: 60rem;
  }
  .hero__eyebrow {
    margin-bottom: var(--space-5);
    opacity: 0;
    animation: rise 0.9s var(--ease-out) 0.05s forwards;
  }
  .hero__title {
    font-size: var(--step-6);
    font-weight: 380;
    letter-spacing: -0.03em;
    line-height: 0.92;
    margin-bottom: var(--space-5);
    /* opacity stays 1 so this LCP element paints on first frame; only transform animates */
    animation: riseSolid 1s var(--ease-out) 0.05s both;
  }
  .hero__lede {
    max-width: 46ch;
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--ink-2);
    margin-bottom: var(--space-6);
    opacity: 0;
    animation: rise 1s var(--ease-out) 0.22s forwards;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    opacity: 0;
    animation: rise 1s var(--ease-out) 0.32s forwards;
  }
  .hero__scroll {
    position: absolute;
    bottom: var(--space-6);
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
    transition: color 0.2s var(--ease);
  }
  .hero__scroll svg {
    animation: nudge 2.4s var(--ease) infinite;
  }
  .hero__scroll:hover {
    color: var(--ink);
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  /* opacity:1 throughout — keeps the hero name eligible as LCP from first paint */
  @keyframes riseSolid {
    from {
      transform: translateY(12px);
    }
    to {
      transform: translateY(0);
    }
  }
  @keyframes nudge {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__eyebrow,
    .hero__title,
    .hero__lede,
    .hero__cta {
      opacity: 1;
      animation: none;
    }
    .hero__scroll svg {
      animation: none;
    }
  }
  @media (max-width: 520px) {
    .hero__title {
      font-size: clamp(2.8rem, 16vw, 4rem);
    }
  }
</style>

<script>
  // Lazy, guarded loader for the three.js "Structure" island.
  // The static SVG lattice is the baseline; this only enhances when:
  //   - motion is allowed (prefers-reduced-motion: no-preference)
  //   - the device is not a small/coarse-pointer screen (battery + scroll)
  //   - WebGL is available
  // three.js is loaded via dynamic import, so it stays in its own lazy chunk
  // and never blocks first paint. Loading is deferred to idle time.
  import type { LatticeHandle } from '../scripts/lattice';

  const mount = document.getElementById('lattice-canvas');

  function hasWebGL(): boolean {
    try {
      const c = document.createElement('canvas');
      return !!(c.getContext('webgl2') || c.getContext('webgl'));
    } catch {
      return false;
    }
  }

  if (mount) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const light = window.matchMedia('(max-width: 820px)').matches ||
      window.matchMedia('(pointer: coarse)').matches;

    if (!reduce && !light && hasWebGL()) {
      let handle: LatticeHandle | null = null;
      const start = () => {
        import('../scripts/lattice')
          .then((m) => {
            handle = m.initLattice(mount);
          })
          .catch(() => {
            /* keep the static SVG fallback on any failure */
          });
      };
      // Wait until the page has loaded, then for an idle gap — the scene must
      // never compete with first paint or LCP on real (especially low-end) devices.
      const idle =
        (window as any).requestIdleCallback ?? ((fn: () => void) => setTimeout(fn, 400));
      const schedule = () => idle(start, { timeout: 2500 });
      if (document.readyState === 'complete') schedule();
      else window.addEventListener('load', schedule, { once: true });

      // Re-evaluate if the user switches on reduced-motion mid-session.
      window
        .matchMedia('(prefers-reduced-motion: reduce)')
        .addEventListener('change', (e) => {
          if (e.matches && handle) {
            handle.dispose();
            handle = null;
          }
        });
    }
  }
</script>
