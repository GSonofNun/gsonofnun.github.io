---
import { Picture } from 'astro:assets';
import type { Project } from '../data/projects';
import { shot } from '../lib/images';

interface Props {
  project: Project;
  variant?: 'feature' | 'standard';
}
const { project, variant = 'standard' } = Astro.props;
const cover = shot(project.shots[0]!.key);
const coverAlt = project.shots[0]!.alt;

// Feature card sits wider, so request larger candidates + matching sizes hint.
const widths =
  variant === 'feature' ? [640, 960, 1280, 1680] : [420, 640, 860, 1200];
const sizes =
  variant === 'feature'
    ? '(min-width: 960px) 760px, 92vw'
    : '(min-width: 1100px) 420px, (min-width: 720px) 46vw, 92vw';
---

<article
  class:list={['card', `card--${variant}`]}
  style={`--ca:${project.accent.base};--cas:${project.accent.soft}`}
  data-project={project.id}
>
  <figure class="card__media">
    <Picture
      src={cover}
      formats={['avif', 'webp']}
      widths={widths}
      sizes={sizes}
      alt={coverAlt}
      loading="lazy"
      decoding="async"
      fetchpriority={variant === 'feature' ? 'high' : 'auto'}
      pictureAttributes={{ class: 'card__picture' }}
    />
    <span class="card__rule" aria-hidden="true"></span>
  </figure>

  <div class="card__body">
    <div class="card__head">
      <h3 class="card__title">
        <button
          class="card__btn"
          type="button"
          aria-haspopup="dialog"
          aria-controls={`dlg-${project.id}`}
          data-open-dialog={`dlg-${project.id}`}
        >
          {project.name}
        </button>
      </h3>
      {project.aka && <span class="card__aka">aka {project.aka}</span>}
      {project.status && <span class="card__badge">{project.status}</span>}
    </div>

    <p class="card__oneliner">{project.oneLiner}</p>
    <p class="card__hook">{project.hook}</p>

    <ul class="card__tags" aria-label="Technologies">
      {project.tech.map((t) => <li>{t}</li>)}
    </ul>

    <span class="card__cue" aria-hidden="true">
      View details
      <svg viewBox="0 0 24 24" width="14" height="14"><path d="M5 12h14m0 0-6-6m6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </span>
  </div>
</article>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg-2);
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.4s var(--ease), border-color 0.4s var(--ease),
      box-shadow 0.4s var(--ease);
    will-change: transform;
  }
  .card::before {
    /* accent hairline along the top edge — the card's local "bloom" */
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ca), var(--cas) 60%, transparent);
    opacity: 0.85;
    z-index: 2;
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in oklab, var(--ca) 45%, var(--hairline-strong));
    box-shadow: var(--shadow-card);
  }

  .card__media {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--bg-3);
    border-bottom: 1px solid var(--hairline);
  }
  .card__media :global(.card__picture),
  .card__media :global(img) {
    width: 100%;
    height: 100%;
  }
  .card__media :global(img) {
    object-fit: cover;
    object-position: top center;
    transition: transform 0.6s var(--ease), filter 0.6s var(--ease);
  }
  .card:hover .card__media :global(img) {
    transform: scale(1.03);
  }
  .card__rule {
    position: absolute;
    inset: 0;
    pointer-events: none;
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--ca) 22%, transparent);
    opacity: 0;
    transition: opacity 0.4s var(--ease);
  }
  .card:hover .card__rule {
    opacity: 1;
  }

  .card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    flex: 1;
  }
  .card__head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }
  .card__title {
    font-size: var(--step-2);
    font-weight: 440;
    letter-spacing: -0.02em;
    margin-right: auto;
  }
  .card__btn {
    color: inherit;
    text-align: left;
    transition: color 0.25s var(--ease);
  }
  .card__btn::after {
    /* stretch the single control over the whole card */
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .card:hover .card__btn {
    color: var(--ca);
  }
  .card__aka {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-3);
    letter-spacing: 0.04em;
  }
  .card__badge {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ca);
    border: 1px solid color-mix(in oklab, var(--ca) 40%, transparent);
    padding: 0.25em 0.6em;
    border-radius: 999px;
    white-space: nowrap;
    align-self: center;
  }
  .card__oneliner {
    font-size: var(--step-0);
    color: var(--ink);
  }
  .card__hook {
    font-size: var(--step--1);
    line-height: 1.55;
    color: var(--ink-2);
  }
  .card__tags {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: auto;
    padding-top: var(--space-3);
  }
  .card__tags li {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.02em;
    color: var(--ink-3);
    border: 1px solid var(--hairline);
    padding: 0.3em 0.6em;
    border-radius: 6px;
  }
  .card__cue {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--ca);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.3s var(--ease), transform 0.3s var(--ease);
  }
  .card:hover .card__cue,
  .card__btn:focus-visible ~ * .card__cue {
    opacity: 1;
    transform: translateX(0);
  }

  /* Feature (flagship) — horizontal on wide screens */
  @media (min-width: 940px) {
    .card--feature {
      flex-direction: row;
    }
    .card--feature .card__media {
      flex: 1 1 58%;
      aspect-ratio: auto;
      border-bottom: none;
      border-right: 1px solid var(--hairline);
    }
    .card--feature .card__body {
      flex: 1 1 42%;
      justify-content: center;
      padding: clamp(var(--space-6), 4vw, var(--space-8));
      gap: var(--space-4);
    }
    .card--feature .card__title {
      font-size: var(--step-4);
    }
    .card--feature .card__oneliner {
      font-size: var(--step-1);
    }
    .card--feature .card__hook {
      font-size: var(--step-0);
    }
  }
</style>
